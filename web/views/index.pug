extends layout

block content
  h1.text-3xl.font-bold.mb-6= title
  if cameras.length === 0
    p.text-gray-400 No cameras found.
  else
    div(class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4")
      each c in cameras
        a.block.p-5.rounded-lg(class="bg-gray-800 hover:bg-gray-700 transition" href="/cam/" + c.name)
          h2.text-xl.font-semibold.mb-2= c.name
          dl.text-sm.text-gray-300.space-y-1
            div
              span.text-gray-500 Recordings:&nbsp;
              span= c.count
            div
              span.text-gray-500 Total size:&nbsp;
              span= fmtSize(c.size)
            div
              span.text-gray-500 Latest:&nbsp;
              span= c.latest ? new Date(c.latest).toLocaleString() : '—'
